  "kf6-kdbusaddons"
  "kf6-kguiaddons"
  "kf6-ki18n"
  "kf6-kiconthemes"
  "kf6-kio"
  "kf6-knewstuff"
  "kf6-kparts"
  "kf6-kservice"
  "kf6-kuserfeedback"
  "kf6-kwidgetsaddons"
  "kf6-kwindowsystem"
  "kf6-kxmlgui"
  "kf6-syntax-highlighting"
  "qt6-base"
)

makedepends=(
  "cmake"
  "kf6-extra-cmake-modules"
  "kf6-kconfig"
  "kf6-kcrash"
  "kf6-kdbusaddons"
  "kf6-kcolorscheme"
  "kf6-kdoctools"
  "kf6-kguiaddons"
  "kf6-ki18n"
  "kf6-kiconthemes"
  "kf6-kitemmodels"
  "kf6-kjobwidgets"
  "kf6-kio"
  "kf6-knewstuff"
  "kf6-kparts"
  "kf6-kpty"
  "kf6-syntax-highlighting"
  "kf6-ktexteditor-dev"
  "kf6-threadweaver-dev"
  "kf6-kwallet"
  "kf6-kwindowsystem"
  "kf6-kuserfeedback-dev"
  "kf6-kxmlgui"
  "plasma-libplasma-dev"
